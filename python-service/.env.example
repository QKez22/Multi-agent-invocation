# AI Embeddings
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
# LLM模型名称: qwen-plus / qwen-max 等 DashScope Tongyi 模型
LLM_MODEL=qwen-plus

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Optional: Milvus Authentication (if enabled)
# MILVUS_USER=username
# MILVUS_PASSWORD=password

# Vector Store Selection (true for Milvus, false for FAISS)
# 默认使用 FAISS（零依赖，本地运行），需要生产级性能可切换 Milvus
USE_MILVUS=false

# Vector Store Configuration
VECTOR_STORE_PERSIST_DIR=./faiss_index
VECTOR_STORE_COLLECTION_NAME=ai_knowledge_collection

# Rerank Configuration
# Rerank type: 'bge' (recommended, local), 'cohere' (requires API key), 'simple' (fallback), 'none' (disabled)
# bge 效果最好但首次需下载 ~1.1GB 模型，开发环境建议用 simple
RERANKER_TYPE=simple

# Optional: Cohere API Key (if using Cohere reranker)
# COHERE_API_KEY=your_cohere_api_key

# Text Chunking Configuration
# Chunk strategy: 'semantic' (recommended), 'recursive' (default)
CHUNK_STRATEGY=semantic
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# Tesseract OCR Configuration
# Tesseract executable path（留空则自动检测常见安装路径）
TESSERACT_PATH=

# Temporary Files Configuration
TEMP_DIR=./temp

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8080

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
